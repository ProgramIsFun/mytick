PORT=4000

# Choose engine: 'mongodb' (default) or 'neo4j'
DB_ENGINE=mongodb

# MongoDB (required if DB_ENGINE=mongodb)
MONGODB_URI=mongodb://localhost:27017/mytick

# Neo4j (required if DB_ENGINE=neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

JWT_SECRET=change-this-to-a-random-secret
ADMIN_API_KEY=change-this-to-a-random-key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
